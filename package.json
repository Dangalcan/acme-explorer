{
  "name": "acme-explorer",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "concurrently \"json-server --watch mock-api/db.json --port 3000\" \"ng serve \"",
    "start:docker": "concurrently \"json-server --watch mock-api/db.json --port 3000\" \"ng serve --host 0.0.0.0\"",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:e2e": "cypress run",
    "test:coverage": "ng test --coverage",
    "serve:ssr:acme-explorer": "node dist/acme-explorer/server/server.mjs",
    "i18n:extract": "ng extract-i18n --output-path src/locale",
    "seed:firestore": "node scripts/seed-firestore.mjs",
    "json-server": "json-server --watch mock-api/db.json --port 3000",
    "start:cypress": "cypress open"
  },
  "private": true,
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "@angular/animations": "^21.2.0",
    "@angular/cdk": "~21.2.2",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/material": "~21.2.2",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-server": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/ssr": "^21.2.0",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "@vitest/coverage-v8": "^4.1.3",
    "express": "^5.1.0",
    "firebase": "^12.10.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.0",
    "@angular/cli": "^21.2.0",
    "@angular/compiler-cli": "^21.2.0",
    "@angular/localize": "21.2.5",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.1.2",
    "cypress": "^15.14.1",
    "jsdom": "^28.0.0",
    "json-server": "^1.0.0-beta.13",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.2",
    "vitest": "^4.1.3"
  }
}
